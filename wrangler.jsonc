{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ilatch",
  "compatibility_date": "2026-05-13",
  "main": "./worker.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true,
    "not_found_handling": "single-page-application"
  },
  "kv_namespaces": [
    {
      "binding": "LATCH_CONFIG","id": "1902dda4dfea482fa5d1dcf3b046ac9c"
    }
  ],
  "vars": {
    "LATCH_ADMIN_EMAILS": "phyzess@gmail.com"
  }
}
