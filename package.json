{
  "name": "ilatch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=26.1.0 <27",
    "pnpm": ">=11.1.1 <12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "cloudflare": {
    "label": "Latch",
    "products": [
      "Workers",
      "Workers KV"
    ],
    "bindings": {
      "LATCH_ADMIN_EMAILS": {
        "description": "Comma-separated email addresses allowed to edit Latch links after signing in through Cloudflare Access."
      },
      "POLICY_AUD": {
        "description": "Cloudflare Access application audience tag from the one-click Access setup modal."
      },
      "TEAM_DOMAIN": {
        "description": "Your Cloudflare Access team URL, for example `https://your-team.cloudflareaccess.com`."
      }
    }
  },
  "scripts": {
    "build": "latch build --out dist",
    "dev": "pnpm build && wrangler dev --port 0",
    "doctor": "latch doctor",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:dry": "pnpm build && wrangler deploy --dry-run"
  },
  "dependencies": {
    "@phyzess/latch": "0.1.1"
  },
  "devDependencies": {
    "wrangler": "4.90.1"
  }
}
